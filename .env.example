# Backend ortam değişkenleri — docker-compose bunları otomatik sağlar.
# Yerelde (Docker'sız) backend çalıştırırsanız bu dosyayı .env yapıp düzenleyin.
MONGO_URL=mongodb://mongo:27017
MONGO_DB=obilet
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
TICKET_QUEUE=ticket_events
CACHE_TTL=60
